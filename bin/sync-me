#!/bin/bash
run() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then
    shift; "$cmd" "$@"
  else
    echo " Warning: $cmd is not available"
  fi
}

sudo pacman -Sc --noconfirm && sudo pacman -Syu --noconfirm
run pass git pull --rebase
run pass git push
run nvim-sync
run obsidian-sync
run backup-bookmarks
