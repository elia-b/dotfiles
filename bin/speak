#!/bin/bash

if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <text_to_echo> <audio_filename_without_extension>"
    exit 1
fi

TEXT_TO_ECHO=$1
FILENAME=$2

FULL_FILENAME="${FILENAME}.mp3"

FILE_PATH="$HOME/.config/speak/$FULL_FILENAME"

if command -v dunstify >/dev/null 2>&1; then
    dunstify -u normal "🗣" "$TEXT_TO_ECHO"
fi

if [ -f "$FILE_PATH" ]; then
    ffplay -nodisp -autoexit -volume 7 "$FILE_PATH" > /dev/null 2>&1
else
    echo "Error: File '$FULL_FILENAME' not found in $HOME/.config/speak/"
    ls -1 "$HOME/.config/speak/" 2>/dev/null || echo "(directory is empty or does not exist)"
    exit 1
fi
